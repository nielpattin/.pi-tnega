{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["skills/**", "**/tests/**", "preciseVerboseReporter.ts"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-control-regex": "off"
  },
  "env": {
    "builtin": true
  }
}